# 이 파일을 api/.env로 복사한 뒤 실제 비밀값을 입력합니다.
# api/.env는 Git으로 추적하지 않습니다.
OPENAI_API_KEY=
GEMINI_API_KEY=

# SQLite는 API 프로젝트의 data/workshield.db 파일을 사용합니다.
DATABASE_URL=sqlite+pysqlite:///./data/workshield.db
DATABASE_ECHO=false
# APP_DEBUG와 API_DOCS_ENABLED는 .env.local/.env.prod 기본값을 사용합니다.
# 환경별 기본값을 바꿔야 할 때만 아래 항목을 주석 해제합니다.
# APP_DEBUG=false
# API_DOCS_ENABLED=false
# 브라우저 접근을 허용할 프론트엔드 origin을 JSON 배열로 지정합니다.
CORS_ORIGINS=["http://localhost:5173"]

# 로컬 개발은 stdio가 uv로 ../mcp 서버를 실행합니다.
# 운영·Docker에서는 streamable_http URL에 연결합니다.
WORKSHIELD_MCP_TRANSPORT=stdio
WORKSHIELD_MCP_PROJECT_DIR=../mcp
WORKSHIELD_MCP_URL=http://localhost:8000/mcp

# 계약서 업로드·검토 세션 설정
MAX_UPLOAD_SIZE_BYTES=10485760
SUPPORTED_FILE_EXTENSIONS=hwp,hwpx,hwpml,pdf,xls,xlsx,docx
TEMP_UPLOAD_DIR=data/99_uploads
# 마지막 사용자 액션 이후 허용하는 비활성 시간
SESSION_TTL_SECONDS=1800
