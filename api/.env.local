# 로컬 개발의 공개 기본값입니다. 실제 API 키는 api/.env에만 둡니다.
APP_ENV=local
APP_DEBUG=false
API_DOCS_ENABLED=true

# 1. OpenAI 사용 시 
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# 2. Gemini / Gemma 사용 시
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-3.5-flash-lite
# LLM_MODEL=gemma-4-31b-it

# 3. Ollama 사용 시 (ollama 스펠링 및 로컬 모델명 지정)
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3.5:9b   # 또는 로컬 ollama list 상의 이름 (e.g. Qwen/Qwen3.5-9B)

# 자체 호스팅 Ollama와 WorkShield MCP 연결 정보입니다.
OLLAMA_BASE_URL=http://localhost:11434
WORKSHIELD_MCP_TRANSPORT=stdio
WORKSHIELD_MCP_PROJECT_DIR=../mcp
WORKSHIELD_MCP_URL=http://localhost:8000/mcp
